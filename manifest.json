{
  "name": "Onetime Secret",
  "author": {
    "name": "Onetime Secret",
    "email": "support@onetimesecret.com",
    "url": "https://onetimesecret.com"
  },
  "defaultLocale": "en",
  "private": false,
  "frameworkVersion": "2.0",
  "singleInstall": true,
  "version": "1.0.0",
  "location": {
    "support": {
      "ticket_sidebar": {
        "url": "assets/iframe.html",
        "flexible": true
      },
      "new_ticket_sidebar": {
        "url": "assets/iframe.html",
        "flexible": true
      }
    }
  },
  "parameters": [
    {
      "name": "apiUsername",
      "type": "text",
      "required": true,
      "secure": false
    },
    {
      "name": "apiKey",
      "type": "text",
      "required": true,
      "secure": true
    },
    {
      "name": "region",
      "type": "text",
      "required": false,
      "secure": false
    },
    {
      "name": "customDomain",
      "type": "text",
      "required": false,
      "secure": false
    },
    {
      "name": "defaultTTL",
      "type": "text",
      "required": false,
      "secure": false
    }
  ],
  "domainWhitelist": [
    "onetimesecret.com",
    "us.onetimesecret.com",
    "eu.onetimesecret.com",
    "ca.onetimesecret.com",
    "uk.onetimesecret.com",
    "nz.onetimesecret.com",
    "{{setting.customDomain}}"
  ]
}

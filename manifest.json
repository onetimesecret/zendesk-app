{
  "name": "Onetime Secret",
  "author": {
    "name": "Onetime Secret",
    "email": "support@onetimesecret.com",
    "url": "https://onetimesecret.com"
  },
  "defaultLocale": "en",
  "private": false,
  "frameworkVersion": "2.0",
  "singleInstall": true,
  "version": "0.2.0",
  "location": {
    "support": {
      "ticket_sidebar": {
        "url": "assets/iframe.html",
        "flexible": true
      },
      "new_ticket_sidebar": {
        "url": "assets/iframe.html",
        "flexible": true
      }
    }
  },
  "parameters": [
    {
      "name": "apiUsername",
      "type": "text",
      "required": true,
      "secure": false,
      "helpText": "Your account identifier or email address"
    },
    {
      "name": "apiKey",
      "type": "text",
      "required": true,
      "secure": true
    },
    {
      "name": "region",
      "type": "text",
      "required": true,
      "secure": false,
      "helpText": "(Required) The region where the links will be created. One of: eu, ca, us, uk, nz"
    },
    {
      "name": "defaultTTL",
      "type": "text",
      "required": false,
      "secure": false,
      "default": "604800",
      "helpText": "(Optional) The amount of time before the secret link expires (in seconds, default is 7 days)"
    },
    {
      "name": "customDomain",
      "type": "text",
      "required": false,
      "secure": false,
      "helpText": "(optional) Your custom domain"
    }
  ],
  "domainWhitelist": [
    "onetimesecret.com",
    "us.onetimesecret.com",
    "eu.onetimesecret.com",
    "ca.onetimesecret.com",
    "uk.onetimesecret.com",
    "nz.onetimesecret.com",
    "{{setting.customDomain}}"
  ]
}
